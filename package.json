{
  "name": "js-libp2p-monorepo",
  "version": "1.0.0",
  "description": "JavaScript implementation of libp2p, a modular peer to peer network stack",
  "license": "Apache-2.0 OR MIT",
  "homepage": "https://github.com/libp2p/js-libp2p#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/libp2p/js-libp2p.git"
  },
  "bugs": {
    "url": "https://github.com/libp2p/js-libp2p/issues"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "scripts": {
    "reset": "aegir run clean && aegir clean interop/node_modules packages/*/node_modules node_modules package-lock.json packages/*/package-lock.json interop/*/package-lock.json",
    "test": "npm run test:node --",
    "test:node": "sh -c 'turbo run test:node -- --build=false --types=false \"$@\"' --",
    "test:chrome": "sh -c 'turbo run test:chrome -- --build=false --types=false \"$@\"' --",
    "test:chrome-webworker": "sh -c 'turbo run test:chrome-webworker -- --build=false --types=false \"$@\"' --",
    "test:firefox": "sh -c 'turbo run test:firefox -- --build=false --types=false \"$@\"' --",
    "test:firefox-webworker": "sh -c 'turbo run test:firefox-webworker -- --build=false --types=false \"$@\"' --",
    "test:electron-main": "sh -c 'turbo run test:electron-main -- --build=false --types=false \"$@\"' --",
    "test:webkit": "sh -c 'turbo run test:webkit -- --build=false --types=false \"$@\"' --",
    "test:cli": "sh -c 'turbo run test:cli -- --build=false --types=false \"$@\"' --",
    "test:interop": "sh -c 'turbo run test:interop -- --build=false --types=false \"$@\"' --",
    "coverage": "sh -c 'turbo run coverage -- --build=false --types=false \"$@\"' --",
    "build": "turbo run build",
    "generate": "turbo run generate",
    "clean": "turbo run clean",
    "lint": "turbo run lint",
    "dep-check": "turbo run dep-check",
    "doc-check": "turbo run doc-check",
    "spell-check": "aegir spell-check",
    "release": "run-s build docs:no-publish npm:release docs",
    "npm:release": "aegir exec --bail false npm -- publish",
    "release:rc": "aegir release-rc",
    "docs": "aegir docs",
    "docs:no-publish": "aegir docs --publish false -- --exclude interop --exclude doc"
  },
  "devDependencies": {
    "aegir": "^47.0.22",
    "npm-run-all": "^4.1.5",
    "turbo": "^2.0.14"
  },
  "workspaces": [
    "doc",
    "interop",
    "packages/*"
  ],
  "overrides": {
    "playwright-core": "1.58.0"
  }
}
